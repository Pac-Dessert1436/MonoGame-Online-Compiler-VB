@page
@model VbCodeEditorModel
@{
    ViewData["Title"] = "VB.NET Code Editor";
}

<div class="container-fluid">
    <div class="row">
        <!-- Left Side: Code Editor -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5>VB.NET Code Editor</h5>
                    <small class="text-muted">Edit GameMain.vb below (Program.vb stays at backend)</small>
                </div>
                <div class="card-body">
                    <form method="post" id="compileForm">
                        <input type="hidden" asp-for="ProjectId" />
                        <input type="hidden" asp-for="UserId" />

                        <div class="mb-3">
                            <label for="vbCode" class="form-label">GameMain.vb</label>
                            <div id="monacoEditor" style="height: 500px; border: 1px solid #ccc; border-radius: 4px;"></div>
                            <input type="hidden" asp-for="VbCode" id="vbCodeHidden" />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.CompilationError))
                        {
                            <div class="alert alert-danger">
                                <strong>Compilation Error:</strong>
                                <pre style="white-space: pre-wrap; word-wrap: break-word;">@Model.CompilationError</pre>
                            </div>
                        }

                        @if (Model.IsCompiling)
                        {
                            <div class="alert alert-info" id="compilingAlert">
                                <div class="d-flex align-items-center">
                                    <div class="spinner-border spinner-border-sm me-2" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <div>
                                        <strong id="compilationStatus">Compiling game code, please wait...</strong>
                                    </div>
                                </div>
                                <p class="mb-0 small text-muted mt-2" id="compilationDetails">
                                    @Model.CompilationStatus - Compilation may take 15-20 seconds. You will be redirected automatically when complete.
                                </p>
                            </div>
                        }

                        <div class="d-flex gap-2">
                            @if (Model.IsCompiling)
                            {
                                <button id="abortButton" type="submit" name="handler" value="Abort" class="btn btn-danger">
                                    <i class="bi bi-x-lg"></i> Abort
                                </button>
                            }
                            else
                            {
                                <button id="compileButton" type="submit" name="handler" value="Compile" class="btn btn-primary">
                                    <i class="bi bi-play-fill"></i> Compile & Run
                                </button>
                            }
                            <button type="button" class="btn btn-success" onclick="saveProject()">
                                <i class="bi bi-save-fill"></i> Save Project
                            </button>
                            <button type="button" class="btn btn-secondary" onclick="resetCode()">
                                <i class="bi bi-arrow-counterclockwise"></i> Reset to Scaffold
                            </button>
                            <button type="button" class="btn btn-warning" onclick="clearBuildCache()" title="Clear build cache (useful if compilation issues occur)">
                                <i class="bi bi-trash"></i> Clear Cache
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Side: Asset Management -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5>Game Assets</h5>
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data" asp-page-handler="BuildContent">
                        <input type="hidden" asp-for="ProjectId" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="VbCode" id="hiddenVbCode" />

                        <div class="mb-3">
                            <label for="assetFiles" class="form-label">Upload Assets</label>
                            <input type="file" class="form-control" id="assetFiles" name="assetFiles" multiple
                                   accept=".png,.jpg,.jpeg,.gif,.bmp,.wav,.mp3,.ogg,.xnb" />
                            <div class="form-text">
                                Supported formats: PNG, JPG, GIF, BMP, WAV, MP3, OGG, XNB
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Current Assets</label>
                            <div class="list-group" id="assetsList">
                                <div class="list-group-item text-muted">
                                    <small>No assets uploaded yet</small>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" name="handler" value="BuildContent" class="btn btn-success">
                                <i class="bi bi-gear-fill"></i> Build Content
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="clearAssets()">
                                <i class="bi bi-trash"></i> Clear Assets
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h5>Help & Tips</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-3">
                        <strong>📚 New to MonoGame?</strong> 
                        <a asp-page="/Tutorial" class="alert-link">Check out our tutorial</a> 
                        for VB.NET developers coming from vbPixelGameEngine!
                    </div>
                    <ul class="small">
                        <li>Edit <code>GameMain.vb</code> in the left editor</li>
                        <li>Upload game assets (images, sounds) on the right</li>
                        <li>Click "Compile & Run" to start compilation, "Abort" to cancel</li>
                        <li>Compilation takes ~15-20 seconds</li>
                        <li>Syntax errors will be shown below the editor</li>
                        <li><code>Program.vb</code> is managed by the backend with fixed content:</li>
                    </ul>
                    <code>
                        Module Program<br>
                        &ensp;&ensp;Sub Main()<br>
                        &ensp;&ensp;&ensp;&ensp;Using game As New GameMain<br>
                        &ensp;&ensp;&ensp;&ensp;&ensp;&ensp;game.Run()<br>
                        &ensp;&ensp;&ensp;&ensp;End Using<br>
                        &ensp;&ensp;End Sub<br>
                        End Module<br>
                    </code>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs/loader.min.js"></script>
    <script>
        let editor;

        require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs' }});
        
        require(['vs/editor/editor.main'], function() {
            editor = monaco.editor.create(document.getElementById('monacoEditor'), {
                value: `@Html.Raw(Model.VbCode.Replace("\r\n", "\n").Replace("\n", "\\n").Replace("\"", "\\\"").Replace("'", "\\'"))`,
                language: 'vb',
                theme: 'hc-black',
                automaticLayout: true,
                fontSize: 12,
                fontFamily: "'Consolas', 'Monaco', monospace",
                minimap: { enabled: false },
                scrollBeyondLastLine: false,
                wordWrap: 'on',
                lineNumbers: 'on',
                renderWhitespace: 'selection',
                tabSize: 4,
                insertSpaces: true
            });

            editor.onDidChangeModelContent(function() {
                const codeValue = editor.getValue();
                document.getElementById('vbCodeHidden').value = codeValue;
                const hiddenVbCode = document.getElementById('hiddenVbCode');
                if (hiddenVbCode) {
                    hiddenVbCode.value = codeValue;
                }
            });
        });

        async function resetCode() {
            if (confirm('Are you sure you want to reset to the scaffold code? All your changes will be lost.')) {
                try {
                    const scaffoldCode = `@Html.Raw(VbCodeEditorModel.ScaffoldCode)`;
                    editor.setValue(scaffoldCode);
                } catch (error) {
                    alert('Failed to load scaffold code: ' + error.message);
                }
            }
        }

        function validateAndSubmit() {
            console.log('validateAndSubmit called');
            const codeValue = editor.getValue();
            console.log('Code length:', codeValue?.length || 0);
            
            if (!codeValue || codeValue.trim() === '') {
                alert('Please enter some VB.NET code before compiling.');
                console.log('Validation failed: Empty code');
                return false;
            }
            
            // Ensure the hidden field is set before submission
            const vbCodeHidden = document.getElementById('vbCodeHidden');
            if (vbCodeHidden) {
                vbCodeHidden.value = codeValue;
                console.log('Set vbCodeHidden value, length:', vbCodeHidden.value.length);
            } else {
                console.error('vbCodeHidden element not found!');
                return false;
            }
            
            console.log('Form validation passed, submitting...');
            return true;
        }

        // Add form submit handler to ensure code is always set and validated
        document.addEventListener('DOMContentLoaded', function() {
            const compileForm = document.getElementById('compileForm');
            if (compileForm) {
                compileForm.addEventListener('submit', function(e) {
                    console.log('Form submit event triggered');
                    
                    // Validate before submission
                    const codeValue = editor.getValue();
                    if (!codeValue || codeValue.trim() === '') {
                        e.preventDefault();
                        alert('Please enter some VB.NET code before compiling.');
                        console.log('Validation failed: Empty code');
                        return;
                    }
                    
                    // Set the hidden field value
                    const vbCodeHidden = document.getElementById('vbCodeHidden');
                    if (vbCodeHidden) {
                        vbCodeHidden.value = codeValue;
                        console.log('Form submit: Set vbCodeHidden value, length:', vbCodeHidden.value.length);
                    }
                    
                    console.log('Form validation passed, submitting...');
                    // Don't prevent default - let the form submit normally
                });
            }
        });

        // Handle asset form submission separately
        const assetForm = document.querySelector('form[enctype="multipart/form-data"]');
        if (assetForm) {
            assetForm.addEventListener('submit', function (e) {
                console.log('Asset form submit event triggered');
                const codeValue = editor.getValue();
                const hiddenVbCode = document.getElementById('hiddenVbCode');
                if (hiddenVbCode) {
                    hiddenVbCode.value = codeValue;
                    console.log('Asset form: Set hiddenVbCode value, length:', hiddenVbCode.value.length);
                }
            });
        }

        document.getElementById('assetFiles').addEventListener('change', function () {
            const files = Array.from(this.files);
            const assetsList = document.getElementById('assetsList');

            if (files.length > 0) {
                assetsList.innerHTML = files.map(file => `
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>${file.name}</span>
                        <span class="badge bg-primary rounded-pill">${formatFileSize(file.size)}</span>
                    </div>
                `).join('');
            } else {
                assetsList.innerHTML = `
                    <div class="list-group-item text-muted">
                        <small>No assets uploaded yet</small>
                    </div>
                `;
            }
        });

        function clearAssets() {
            document.getElementById('assetFiles').value = '';
            document.getElementById('assetsList').innerHTML = `
                <div class="list-group-item text-muted">
                    <small>No assets uploaded yet</small>
                </div>
            `;
        }

        async function clearBuildCache() {
            const projectId = document.getElementById('ProjectId').value;
            const userId = document.getElementById('UserId').value;
            
            if (confirm('Are you sure you want to clear the build cache? This may make the next compilation slower, but can help resolve compilation issues.')) {
                try {
                    const response = await fetch(`/api/monogame/cache/${userId}/${projectId}`, {
                        method: 'DELETE'
                    });
                    
                    if (response.ok) {
                        alert('Build cache cleared successfully. The next compilation will be a full build.');
                    } else {
                        const error = await response.json();
                        alert('Failed to clear cache: ' + (error.Message || 'Unknown error'));
                    }
                } catch (error) {
                    alert('Error clearing cache: ' + error.message);
                }
            }
        }

        async function saveProject() {
            const codeValue = editor.getValue();
            const projectId = document.getElementById('ProjectId').value;
            const userId = document.getElementById('UserId').value;
            
            if (!codeValue || codeValue.trim() === '') {
                alert('Please enter some VB.NET code before saving.');
                return;
            }
            
            try {
                const response = await fetch(`/api/project/${projectId}?userId=${userId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        userId: parseInt(userId),
                        name: '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProjectName))',
                        vbCode: codeValue
                    })
                });
                
                if (response.ok) {
                    alert('Project saved successfully!');
                } else {
                    const error = await response.json();
                    alert('Failed to save project: ' + (error.Message || 'Unknown error'));
                }
            } catch (error) {
                alert('Error saving project: ' + error.message);
            }
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // Check compilation status if a compilation is in progress
        let compilationCheckInterval;
        const pollingInterval = 3000; // Check every 3 seconds
        const maxPollingTime = 180000; // Maximum 3 minutes polling time
        let pollingStartTime;
        
        document.addEventListener('DOMContentLoaded', function() {
            const gameId = '@Model.CompilationGameId';
            const gameUrl = '@Model.GameUrl';
            const isCompiling = '@Model.IsCompiling.ToString().ToLower()';
            
            // If GameUrl is set, redirect to GameRunner immediately
            if (gameUrl && gameUrl.includes('GameRunner')) {
                console.log('Compilation complete, redirecting to:', gameUrl);
                setTimeout(() => {
                    window.location.href = gameUrl;
                }, 1000);
                return;
            }
            
            if (isCompiling === 'true' && gameId) {
                pollingStartTime = Date.now();
                checkCompilationStatus();
            }
        });
        
        async function checkCompilationStatus() {
            const gameId = '@Model.CompilationGameId';
            const elapsed = Date.now() - pollingStartTime;
            
            // Stop polling after maximum time
            if (elapsed > maxPollingTime) {
                console.log('Maximum polling time reached, stopping');
                clearInterval(compilationCheckInterval);
                return;
            }
            
            const parts = gameId.split('_');
            
            if (parts.length >= 4) {
                const sessionId = parts.slice(3).join('_');
                
                try {
                    const response = await fetch(`/api/project/session/${sessionId}`);
                    
                    if (response.ok) {
                        const session = await response.json();
                        
                        console.log('Compilation session status:', session);
                        
                        if (session.completedAt) {
                            clearInterval(compilationCheckInterval);
                            
                            const statusText = document.getElementById('compilationStatus');
                            
                            if (statusText) {
                                statusText.textContent = session.success ? 'Compilation complete!' : 'Compilation failed!';
                            }
                            
                            if (session.success) {
                                setTimeout(() => {
                                    window.location.href = '/GameRunner?gameId=' + gameId;
                                }, 500);
                            } else {
                                setTimeout(() => {
                                    window.location.reload();
                                }, 2000);
                            }
                        } else {
                            // Compilation still in progress, continue polling
                            compilationCheckInterval = setTimeout(checkCompilationStatus, pollingInterval);
                        }
                    } else if (response.status === 404) {
                        console.log('Session not found, checking game status...');
                        const statusResponse = await fetch(`/api/monogame/status/${gameId}`);
                        if (statusResponse.ok) {
                            const statusResult = await statusResponse.json();
                            console.log('Game status:', statusResult);
                            
                            // Check if compilation was successful
                            if (statusResult.success === true || statusResult.Success === true) {
                                clearInterval(compilationCheckInterval);
                                
                                const statusText = document.getElementById('compilationStatus');
                                if (statusText) {
                                    statusText.textContent = 'Compilation complete!';
                                }
                                
                                const gameIdToUse = statusResult.gameId || statusResult.GameId || gameId;
                                setTimeout(() => {
                                    window.location.href = '/GameRunner?gameId=' + gameIdToUse;
                                }, 500);
                            } else if (statusResult.success === false || statusResult.Success === false || statusResult.Status === 'NotFound') {
                                clearInterval(compilationCheckInterval);
                                
                                const statusText = document.getElementById('compilationStatus');
                                if (statusText) {
                                    statusText.textContent = 'Compilation failed!';
                                }
                                
                                setTimeout(() => {
                                    window.location.reload();
                                }, 2000);
                            } else {
                                // Status not determined, continue polling
                                compilationCheckInterval = setTimeout(checkCompilationStatus, pollingInterval);
                            }
                        } else {
                            // Status check failed, continue polling
                            compilationCheckInterval = setTimeout(checkCompilationStatus, pollingInterval);
                        }
                    } else {
                        console.error('Failed to check compilation session status:', response.status, response.statusText);
                        // Continue polling even if there's an error
                        compilationCheckInterval = setTimeout(checkCompilationStatus, pollingInterval);
                    }
                } catch (error) {
                    console.error('Error checking compilation status:', error);
                    // Continue polling even if there's an error
                    compilationCheckInterval = setTimeout(checkCompilationStatus, pollingInterval);
                }
            }
        }
    </script>
}