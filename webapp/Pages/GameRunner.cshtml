@page "{gameId}"
@model GameRunnerModel
@{
    ViewData["Title"] = "Game Runner";
}

<div class="container-fluid h-100">
    <div class="row h-100">
        <!-- Game Display Area -->
        <div class="col-12">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Game Runner</h5>
                    <div class="d-flex gap-2">
                        <span class="badge bg-@(Model.GameStatus == "Ready" ? "success" : "warning")">
                            Status: @Model.GameStatus
                        </span>
                        <a asp-page="/VbCodeEditor" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i> Back to Code Editor
                        </a>
                    </div>
                </div>
                <div class="card-body p-0" style="height: calc(100vh - 200px);">
                    @if (!string.IsNullOrEmpty(Model.CompilationError))
                    {
                        <!-- Compilation Error Display -->
                        <div class="alert alert-danger m-3">
                            <h5 class="alert-heading">
                                <i class="bi bi-exclamation-triangle-fill"></i> Compilation Error
                            </h5>
                            <hr>
                            <p class="mb-0">@Model.CompilationError</p>
                            
                            @if (!string.IsNullOrEmpty(Model.CompilationOutput))
                            {
                                <details class="mt-3">
                                    <summary>View Compilation Output</summary>
                                    <pre class="mt-2 p-3 bg-light border rounded" style="max-height: 300px; overflow: auto;">@Model.CompilationOutput</pre>
                                </details>
                            }
                            
                            <div class="mt-3">
                                <a asp-page="/VbCodeEditor" class="btn btn-primary">
                                    <i class="bi bi-pencil"></i> Fix Code
                                </a>
                            </div>
                        </div>
                    }
                    else if (Model.GameStatus == "Ready")
                    {
                        <!-- Game Iframe -->
                        <iframe id="gameFrame" 
                                src="@Model.GameUrl" 
                                class="w-100 h-100 border-0"
                                style="min-height: 600px;"
                                allowfullscreen>
                        </iframe>
                    }
                    else
                    {
                        <!-- Loading State -->
                        <div class="d-flex flex-column justify-content-center align-items-center h-100">
                            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-3 text-muted">Loading game...</p>
                            <p class="small text-muted">
                                This may take a moment. If the game doesn't load, check for compilation errors below.
                            </p>
                            
                            <div class="mt-4">
                                <button class="btn btn-outline-secondary" onclick="refreshGame()">
                                    <i class="bi bi-arrow-clockwise"></i> Refresh Game
                                </button>
                                <a asp-page="/VbCodeEditor" class="btn btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Back to Code Editor
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh game status if not ready
        let refreshInterval;
        
        document.addEventListener('DOMContentLoaded', function() {
            const status = '@Model.GameStatus';
            
            if (status !== 'Ready' && status !== 'NotFound') {
                // Check status every 3 seconds
                refreshInterval = setInterval(checkGameStatus, 3000);
            }
        });

        async function checkGameStatus() {
            try {
                const response = await fetch(`/api/monogame/status/@Model.GameId`);
                if (response.ok) {
                    const result = await response.json();
                    
                    if (result.Status === 'Ready') {
                        // Game is ready, reload the page
                        clearInterval(refreshInterval);
                        window.location.reload();
                    } else if (result.Status === 'NotFound') {
                        // Game not found
                        clearInterval(refreshInterval);
                        window.location.reload();
                    }
                }
            } catch (error) {
                console.error('Error checking game status:', error);
            }
        }

        function refreshGame() {
            const iframe = document.getElementById('gameFrame');
            if (iframe) {
                iframe.src = iframe.src;
            } else {
                window.location.reload();
            }
        }

        // Handle iframe errors
        document.addEventListener('DOMContentLoaded', function() {
            const iframe = document.getElementById('gameFrame');
            if (iframe) {
                iframe.onerror = function() {
                    alert('Failed to load game. Please check if the game compiled successfully.');
                };
            }
        });
    </script>
}